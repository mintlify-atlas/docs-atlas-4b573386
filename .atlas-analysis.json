    "NSFW content detection",
    "Rate limiting and spam prevention",
    "Passkey authentication",
    "College-based communities"
  ],
  "publicApiSurface": [
    "POST /api/post - Create a post",
    "DELETE /api/post - Delete a post",
    "POST /api/post/reply - Reply to a post",
    "POST /api/post/toggle/like - Toggle post like",
    "POST /api/post/toggle/dislike - Toggle post dislike",
    "POST /api/post/toggle/repost - Toggle repost",
    "GET /api/posts - Get feed posts",
    "GET /api/post/[id]/thread - Get post thread",
    "GET /api/post/[id]/replies - Get post replies",
    "POST /api/follow - Follow/unfollow user",
    "GET /api/follow/is - Check follow status",
    "GET /api/profile/[handle] - Get user profile",
    "POST /api/profile/[handle]/edit - Edit profile",
    "GET /api/profile/[handle]/posts - Get user posts",
    "GET /api/profile/[handle]/replies - Get user replies",
    "GET /api/profile/[handle]/reposts - Get user reposts",
    "POST /api/profile/report - Report user",
    "GET /api/college/[id] - Get college info",
    "GET /api/search - Search users and posts",
    "POST /api/auth/signup - Sign up user",
    "GET /api/checkUserNameAvailability - Check username"
  ]
